<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/report_issue_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Issue Type"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/report_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Location" />

    <TextView
        android:id="@+id/report_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Description" />

    <TextView
        android:id="@+id/report_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Status" />

    <TextView
        android:id="@+id/report_timestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Timestamp" />

    <ImageView
        android:id="@+id/report_photo"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Report photo"
        android:scaleType="centerCrop"
        android:visibility="gone" />
</LinearLayout>
