<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/eco_image_bg">

    <!-- AppBar with Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Visitor Check-In"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Progress Indicator -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_checkin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                app:indicatorColor="@color/green"
                app:indicatorSize="48dp"
                app:trackThickness="4dp" />

            <!-- Check-In Options -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckInQR"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Scan QR Code"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/green"
                        app:icon="@drawable/ic_qr_code"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:cornerRadius="30dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckInGPS"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Check-In with GPS"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/green_dark"
                        android:layout_marginTop="16dp"
                        app:icon="@drawable/ic_gps"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:cornerRadius="30dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckInHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Check-In History"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/green"
                        android:layout_marginTop="16dp"
                        app:icon="@drawable/ic_history"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:cornerRadius="30dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/white">

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: Not checked in"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:padding="20dp"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Eco-Capacity Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCapacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/txtCapacityLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Eco-Capacity: Low"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32" />

                    <TextView
                        android:id="@+id/txtCapacityCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Visitors today: 0/100"
                        android:textSize="14sp"
                        android:textColor="#455A64"
                        android:paddingTop="6dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_capacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        app:indicatorColor="@color/green"
                        app:trackColor="#C8E6C9"
                        app:trackThickness="6dp" />

                    <TextView
                        android:id="@+id/txtCapacityHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Plenty of space. Enjoy your visit!"
                        android:textSize="14sp"
                        android:textColor="#455A64"
                        android:paddingTop="10dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Badge (Optional for Check-In Success) -->
    <ImageView
        android:id="@+id/iv_checkin_badge"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_checkin_badge"
        android:contentDescription="Check-In Success Badge"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
