<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutline"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon -->
        <ImageView
            android:id="@+id/iv_tip_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_eco_leaf"
            android:contentDescription="Tip icon"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorPrimary"
            android:padding="8dp" />

        <!-- Text Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_tip_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Use Public Transport"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_tip_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reduce carbon emissions by using buses, trains, or carpools."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Optional Completion Progress -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_tip"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:indicatorSize="36dp"
            app:trackThickness="4dp"
            app:indicatorColor="?attr/colorPrimary"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
