<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ==================== SHAPE APPEARANCE OVERLAYS ==================== -->

    <!-- Button shape with 8dp rounded corners -->
    <style name="ShapeAppearanceOverlay.EcoButton" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Card shape with 16dp rounded corners -->
    <style name="ShapeAppearanceOverlay.DashboardCard" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Card shape with 12dp rounded corners -->
    <style name="ShapeAppearanceOverlay.SmallCard" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- ==================== BUTTONS ==================== -->

    <!-- Primary Eco Button -->
    <style name="EcoButton" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.EcoButton</item>
        <item name="android:backgroundTint">@color/forest_green</item>
    </style>

    <!-- Primary and Secondary Buttons for theme -->
    <style name="Widget.FypEcoTourism.Button.Primary" parent="EcoButton" />

    <style name="Widget.FypEcoTourism.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.EcoButton</item>
        <item name="android:backgroundTint">@color/light_brown</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- ==================== TEXT STYLES ==================== -->

    <style name="DestinationTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">?android:textColorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="DescriptionText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:padding">4dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.FypEcoTourism.TextView.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/dark_green</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.FypEcoTourism.TextView.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/dark_gray</item>
    </style>

    <!-- ==================== SPINNER ==================== -->

    <style name="EcoSpinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/spinner_background</item>
        <item name="android:popupBackground">@color/white</item>
        <item name="android:padding">8dp</item>
        <item name="android:spinnerMode">dropdown</item>
        <item name="android:dropDownVerticalOffset">4dp</item>
        <item name="android:textColor">?android:textColorPrimary</item>
    </style>

    <!-- ==================== EDITTEXT / TEXT INPUT ==================== -->

    <style name="EcoEditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="android:textColor">?android:textColorPrimary</item>
        <item name="hintTextColor">?android:textColorSecondary</item>
        <item name="boxStrokeColor">@color/forest_green</item>
        <item name="android:padding">8dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.FypEcoTourism.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/forest_green</item>
        <item name="hintTextColor">@color/dark_gray</item>
    </style>

    <!-- ==================== CARDS ==================== -->

    <style name="DashboardCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_margin">8dp</item>
        <item name="cardElevation">6dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.DashboardCard</item>
        <item name="android:background">@color/eco_background</item>
    </style>

    <style name="Widget.FypEcoTourism.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="android:background">@color/light_brown</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.SmallCard</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- ==================== THEME ==================== -->

    <style name="Theme.FypEcoTourism" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/forest_green</item>
        <item name="colorPrimaryVariant">@color/dark_green</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/leaf_green</item>
        <item name="colorSecondaryVariant">@color/earth_brown</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/eco_background</item>
        <item name="colorOnSurface">@color/black</item>

        <item name="colorError">@android:color/holo_red_dark</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/dark_gray</item>
    </style>

</resources>
