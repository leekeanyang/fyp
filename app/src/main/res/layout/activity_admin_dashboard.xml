<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:background="?attr/colorPrimaryVariant">

            <!-- Header -->
            <TextView
                android:id="@+id/tv_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp" />

            <!-- Reports Card with Badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_reports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_reports_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pending Reports"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground" />

                    <TextView
                        android:id="@+id/tv_report_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/badge_background"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:visibility="gone"
                        android:contentDescription="Number of pending reports" />
                </LinearLayout>

                <ListView
                    android:id="@+id/lv_reports"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="8dp"
                    android:padding="16dp"
                    android:contentDescription="List of pending reports" />

                <Button
                    android:id="@+id/btn_resolve_reports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resolve Reports"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    android:padding="12dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:tooltipText="Navigate to resolve pending reports"
                    android:contentDescription="Resolve pending reports" />
            </androidx.cardview.widget.CardView>

            <!-- Capacity Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_capacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cv_reports"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_capacity_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Site Capacities"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground" />

                    <TextView
                        android:id="@+id/tv_royal_belum_capacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Royal Belum: 150/200 (Moderate)"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Royal Belum capacity status" />

                    <TextView
                        android:id="@+id/tv_kuala_sepetang_capacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kuala Sepetang: 80/150 (Low)"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"
                        android:contentDescription="Kuala Sepetang capacity status" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <Button
                            android:id="@+id/btn_decrement_royal_belum"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-"
                            android:padding="12dp"
                            android:tooltipText="Decrease visitor count"
                            android:contentDescription="Decrease Royal Belum visitor count" />

                        <EditText
                            android:id="@+id/et_royal_belum_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:hint="Enter count"
                            android:inputType="number"
                            android:text="150"
                            android:padding="12dp"
                            android:textAlignment="center" />

                        <Button
                            android:id="@+id/btn_increment_royal_belum"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="+"
                            android:padding="12dp"
                            android:tooltipText="Increase visitor count"
                            android:contentDescription="Increase Royal Belum visitor count" />

                        <Button
                            android:id="@+id/btn_set_royal_belum"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Set"
                            android:padding="12dp"
                            android:tooltipText="Set custom visitor count"
                            android:contentDescription="Set Royal Belum visitor count" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_royal_belum_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Reason for change"
                        android:padding="12dp"
                        android:text="e.g., Closed due to rain"
                        android:contentDescription="Reason for visitor count change" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Analytics Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_analytics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cv_capacity"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btn_toggle_analytics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Expand Analytics"
                        android:backgroundTint="#2E7D32"
                        android:textColor="#FFFFFF"
                        android:padding="12dp"
                        android:tooltipText="Expand or collapse analytics section"
                        android:contentDescription="Toggle analytics section" />

                    <LinearLayout
                        android:id="@+id/ll_analytics_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_analytics_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analytics (Last 7 Days)"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnBackground" />

                        <TextView
                            android:id="@+id/tv_analytics_reports"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Litter Reports: 5, Wildlife Disturbance: 2"
                            android:textSize="16sp"
                            android:layout_marginTop="8dp"
                            android:contentDescription="Report analytics for last 7 days" />

                        <TextView
                            android:id="@+id/tv_analytics_capacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Avg Visitors (Royal Belum): 120/day"
                            android:textSize="16sp"
                            android:layout_marginTop="8dp"
                            android:contentDescription="Average visitor analytics" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Control Buttons -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_controls"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cv_analytics"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btn_refresh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Refresh Data"
                        android:backgroundTint="#2E7D32"
                        android:textColor="#FFFFFF"
                        android:padding="12dp"
                        android:tooltipText="Refresh all data"
                        android:contentDescription="Refresh dashboard data" />

                    <Button
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Logout"
                        android:backgroundTint="#D32F2F"
                        android:textColor="#FFFFFF"
                        android:padding="12dp"
                        android:tooltipText="Log out of admin account"
                        android:contentDescription="Logout button" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Progress Indicator -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>