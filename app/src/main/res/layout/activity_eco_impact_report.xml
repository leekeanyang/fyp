<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🌲 Header Banner -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/header_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/eco_banner" />

            <!-- Overlay Text -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Eco Impact Reporting"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_bg_eco"
            android:layout_margin="16dp"
            android:elevation="6dp">

            <!-- Dropdown: Issue Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type of Issue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:paddingBottom="6dp" />

            <Spinner
                android:id="@+id/spinner_issue_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown"
                android:background="@drawable/spinner_bg" />

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:paddingTop="16dp"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/edit_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Add GPS or pin location"
                android:inputType="text"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:textColor="#2C3E50"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_use_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Use Current Location"
                android:layout_marginTop="10dp"
                android:backgroundTint="#66BB6A"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@android:color/white" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:paddingTop="16dp"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/edit_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Describe the issue..."
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:background="@drawable/input_bg"
                android:padding="12dp"
                android:textColor="#2C3E50"
                android:textSize="15sp" />

            <!-- Upload Photo -->
            <Button
                android:id="@+id/btn_upload_photo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📷 Upload Photo"
                android:layout_marginTop="16dp"
                android:backgroundTint="#4CAF50"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white" />

            <!-- Status -->
            <TextView
                android:id="@+id/tv_photo_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No photo selected"
                android:textSize="14sp"
                android:textColor="#546E7A"
                android:paddingTop="6dp" />

            <!-- Preview Selected Photo -->
            <ImageView
                android:id="@+id/img_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:background="#E0E0E0"
                android:contentDescription="Photo Preview"
                android:adjustViewBounds="true" />

            <!-- Submit -->
            <Button
                android:id="@+id/btn_submit_report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Submit Report"
                android:backgroundTint="#2E7D32"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="20dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
